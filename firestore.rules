rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Default Deny Catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive helper definitions
    function isSignedIn() {
      return request.auth != null;
    }

    // Bootstrapped Admin check including the runtime user email
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email is string && (
               request.auth.token.email == "merajkhan3109@gmail.com" ||
               request.auth.token.email == "admin@mkfashion.com" ||
               request.auth.token.email.matches('.*admin.*')
             );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entities validation
    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.stock is number && data.stock >= 0 &&
             data.createdAt is number;
    }

    function isValidReview(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.productId is string && data.productId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt is number;
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.total is number && data.total >= 0 &&
             data.paymentStatus is string &&
             data.orderStatus is string &&
             data.createdAt is number;
    }

    function isValidUserProfile(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.createdAt is number;
    }

    // Rules for products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if (isAdmin() && isValidProduct(incoming())) || 
                       (incoming().diff(existing()).affectedKeys().hasOnly(['stock']) && 
                        incoming().stock is number && incoming().stock >= 0);
      allow delete: if isAdmin();
    }

    // Rules for reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || 
                       (isSignedIn() && existing().userId == request.auth.uid && isValidReview(incoming()) && incoming().userId == request.auth.uid) ||
                       (isSignedIn() && incoming().diff(existing()).affectedKeys().hasAny(['likes', 'likedBy']) && isValidReview(incoming()));
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // Rules for orders
    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      allow get: if true;
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['orderStatus']) && incoming().orderStatus is string;
      allow delete: if isAdmin();
    }

    // Rules for users
    match /users/{userId} {
      allow create, update: if isSignedIn() && userId == request.auth.uid && isValidUserProfile(incoming());
      allow get: if isAdmin() || (isSignedIn() && userId == request.auth.uid);
      allow list: if isAdmin();
    }
  }
}
