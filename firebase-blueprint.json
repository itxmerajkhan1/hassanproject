{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents a luxury fashion product in the catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the product" },
        "name": { "type": "string", "maxLength": 100, "description": "The product's name" },
        "description": { "type": "string", "maxLength": 2000, "description": "The detailed product story" },
        "price": { "type": "number", "description": "Current selling price" },
        "originalPrice": { "type": "number", "description": "Original retail price" },
        "category": { "type": "string", "description": "Product collection category" },
        "images": { "type": "array", "description": "Image gallery URLs" },
        "sizes": { "type": "array", "description": "Available size tags" },
        "colors": { "type": "array", "description": "Available color structures" },
        "rating": { "type": "number", "description": "Weighted average review rating" },
        "reviewCount": { "type": "number", "description": "Total count of reviews" },
        "stock": { "type": "number", "description": "Inventory stock level" },
        "isFeatured": { "type": "boolean", "description": "Featured status" },
        "isNewArrival": { "type": "boolean", "description": "New release status" },
        "createdAt": { "type": "number", "description": "Unix timestamp of creation" },
        "sku": { "type": "string", "description": "Registry SKU tag" },
        "brand": { "type": "string", "description": "Atelier brand name" },
        "fabric": { "type": "string", "description": "Atelier fabric composition" },
        "careInstructions": { "type": "string", "description": "Care instructions" },
        "shippingInfo": { "type": "string", "description": "Shipping information" },
        "returnPolicy": { "type": "string", "description": "Return policy" }
      },
      "required": ["id", "name", "price", "category", "stock", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user-submitted product review.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique review identifier" },
        "productId": { "type": "string", "description": "Referenced product ID" },
        "userId": { "type": "string", "description": "Author user ID" },
        "userName": { "type": "string", "maxLength": 80, "description": "Author name" },
        "rating": { "type": "number", "description": "Rating score (1 to 5)" },
        "comment": { "type": "string", "maxLength": 1000, "description": "Review commentary text" },
        "createdAt": { "type": "number", "description": "Unix timestamp of creation" }
      },
      "required": ["id", "productId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An e-commerce order representing a customer purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order identifier" },
        "userId": { "type": "string", "description": "The customer's user ID or guest identifier" },
        "email": { "type": "string", "description": "Customer email" },
        "items": { "type": "array", "description": "Line items bought" },
        "total": { "type": "number", "description": "Total order charge" },
        "shippingAddress": { "type": "object", "description": "Shipping address components" },
        "paymentStatus": { "type": "string", "enum": ["paid", "pending", "failed"], "description": "Status of the payment" },
        "orderStatus": { "type": "string", "enum": ["processing", "shipped", "delivered", "cancelled"], "description": "Order processing status" },
        "createdAt": { "type": "number", "description": "Unix timestamp of checkout" }
      },
      "required": ["id", "userId", "email", "items", "total", "shippingAddress", "paymentStatus", "orderStatus", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with wishlist information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "description": "User's email" },
        "displayName": { "type": "string", "maxLength": 100, "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's avatar URL" },
        "createdAt": { "type": "number", "description": "Unix timestamp of registration" },
        "wishlist": { "type": "array", "description": "Array of favorited product IDs" }
      },
      "required": ["uid", "email", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collections of premium luxury garments and accessories."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Customer reviews and product rating entries."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order purchase invoices."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User registration profiles and wishlists."
    }
  }
}
